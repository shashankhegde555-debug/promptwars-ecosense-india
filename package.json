    "@google-cloud/logging": "^11.2.2",
    "@google-cloud/secret-manager": "^6.1.3",
    "@google-cloud/storage": "^7.19.0",
    "@google/generative-ai": "^0.24.1",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "firebase": "^12.14.0",
    "helmet": "^8.2.0",
    "node-cache": "^5.1.2",
    "pino": "^10.3.1",
    "prop-types": "^15.8.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "recharts": "^3.8.1",
    "uuid": "^14.0.0",
    "xss": "^1.0.15",
    "zod": "^4.4.3"
