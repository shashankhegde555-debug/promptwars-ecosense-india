{
  "name": "ecosense-india",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"node server.js\"",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ server/ server.js",
    "format": "prettier --write \"src/**/*.{js,jsx}\" \"server/**/*.js\" \"server.js\""
  },
  "dependencies": {
    "@google-cloud/bigquery": "^8.3.1",
