# === Gemini AI ===
GEMINI_API_KEY=your-gemini-api-key-here

# === Firebase (Firebase Console > Project Settings > Your apps > Config) ===
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=ecosense-india.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=ecosense-india
VITE_FIREBASE_STORAGE_BUCKET=ecosense-india.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_MEASUREMENT_ID=your-measurement-id

# === GCP ===
GCP_PROJECT_ID=ecosense-india
GCS_BUCKET_NAME=ecosense-india-analytics
BIGQUERY_DATASET=ecosense_analytics

# === Server ===
NODE_ENV=development
PORT=3001
VITE_API_URL=http://localhost:3001
